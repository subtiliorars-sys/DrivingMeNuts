{
  "name": "driving-me-nuts-desktop",
  "productName": "Driving Me Nuts",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop (Steam / Windows) shell for Driving Me Nuts — a cozy roasted-peanut food-truck RPG + idle game.",
  "license": "UNLICENSED",
  "main": "main.cjs",
  "scripts": {
    "make-icon": "node scripts/make-icon.cjs",
    "copy-dist": "node scripts/copy-dist.cjs",
    "prestart": "npm run copy-dist",
    "start": "electron .",
    "electron:dev": "node scripts/dev.cjs",
    "prepackage": "npm run make-icon && npm run copy-dist",
    "package:dir": "electron-builder --dir",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.drivingmenuts.game",
    "productName": "Driving Me Nuts",
    "copyright": "Copyright © 2026. All rights reserved.",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "dist/**/*",
      "build/icon.*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png",
      "artifactName": "DrivingMeNuts-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Driving Me Nuts"
    },
    "portable": {
      "artifactName": "DrivingMeNuts-${version}-portable.exe"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.games"
    }
  }
}
