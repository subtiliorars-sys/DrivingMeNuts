{
  "name": "driving-me-nuts",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "start": "vite --open",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:boot": "vitest run --config vitest.boot.config.ts",
    "qa:browser": "powershell -ExecutionPolicy Bypass -File ./scripts/browser-qa.ps1 -Action tutorial-smoke",
    "art": "node tools/art/build-assets.cjs",
    "verify": "tsc --noEmit && vitest run && npm run test:boot && vite build",
    "desktop:setup": "npm --prefix desktop install",
    "desktop:run": "npm run build && npm --prefix desktop start",
    "package:win": "npm run build && npm --prefix desktop run package:win",
    "package:desktop": "npm run build && npm --prefix desktop run package:dir"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
